# Normalize line endings by default
*           text=auto

# Windows scripts / MSVC
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.sln       text eol=crlf
*.vcxproj   text eol=crlf
*.props     text eol=crlf

# Unix / CI
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary artifacts / database files
*.zip       binary
*.7z        binary
*.exe       binary
*.dll       binary
*.so        binary
*.lib       binary
*.a         binary
*.obj       binary
*.o         binary
*.pdb       binary
*.dbf       binary
*.dbt       binary
*.fpt       binary
*.dtx       binary
*.inx       binary
*.cdx       binary
*.cnx       binary