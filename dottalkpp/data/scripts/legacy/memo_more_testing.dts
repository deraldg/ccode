ECHO OFF
SET TALK ON

* =========================================================
* MEM64_TEST — SCHEMAS SAVE/LOAD X64 MEMO HARMONY TEST
* =========================================================
* PURPOSE
*   1) Build three x64 memo tables
*   2) Open them into controlled workareas
*   3) Save workspace as mem64_test.dtschemas
*   4) Reload workspace cleanly
*   5) Prove each area keeps its own memo state
*   6) Prove closing one area does not disturb the others
*   7) Prove SCHEMAS LOAD restores the layout again
* =========================================================

CLOSE ALL
SCHEMAS CLOSE

ERASE X64_A CONFIRM
ERASE X64_B CONFIRM
ERASE X64_C CONFIRM

* ---------------------------------------------------------
* BUILD TABLE A
* ---------------------------------------------------------
CREATE X64 X64_A (ID N(8,0), TITLE C(20), NOTES M)
APPEND
REPLACE ID WITH 1
REPLACE TITLE WITH A1
REPLACE NOTES WITH "alpha one"
CLOSE

* ---------------------------------------------------------
* BUILD TABLE B
* ---------------------------------------------------------
CREATE X64 X64_B (ID N(8,0), TITLE C(20), NOTES M)
APPEND
REPLACE ID WITH 1
REPLACE TITLE WITH B1
REPLACE NOTES WITH "bravo one"
CLOSE

* ---------------------------------------------------------
* BUILD TABLE C
* ---------------------------------------------------------
CREATE X64 X64_C (ID N(8,0), TITLE C(20), NOTES M)
APPEND
REPLACE ID WITH 1
REPLACE TITLE WITH C1
REPLACE NOTES WITH "charlie one"
CLOSE

* ---------------------------------------------------------
* OPEN INTO KNOWN SLOTS
* ---------------------------------------------------------
SELECT 0
USE X64_A

SELECT 1
USE X64_B

SELECT 2
USE X64_C

SCHEMAS
WSREPORT ALL

* ---------------------------------------------------------
* SAVE CONTROLLED WORKSPACE
* ---------------------------------------------------------
SCHEMAS SAVE mem64_test.dtschemas

* ---------------------------------------------------------
* CLEAR EVERYTHING, THEN RELOAD CLEANLY
* ---------------------------------------------------------
SCHEMAS CLOSE
SCHEMAS LOAD mem64_test.dtschemas

SCHEMAS
WSREPORT ALL

* ---------------------------------------------------------
* CHECK EACH AREA AFTER LOAD
* ---------------------------------------------------------
SELECT 0
AREA
DISPLAY
TUP

SELECT 1
AREA
DISPLAY
TUP

SELECT 2
AREA
DISPLAY
TUP

* ---------------------------------------------------------
* UPDATE EACH AREA SEPARATELY
* ---------------------------------------------------------
SELECT 0
REPLACE NOTES WITH "alpha updated"
DISPLAY
TUP

SELECT 1
REPLACE NOTES WITH "bravo updated"
DISPLAY
TUP

SELECT 2
REPLACE NOTES WITH "charlie updated"
DISPLAY
TUP

* ---------------------------------------------------------
* RECHECK EACH AREA
* ---------------------------------------------------------
SELECT 0
DISPLAY
TUP

SELECT 1
DISPLAY
TUP

SELECT 2
DISPLAY
TUP

* ---------------------------------------------------------
* CLOSE ONE AREA ONLY
* ---------------------------------------------------------
SCHEMAS CLOSE 1

SCHEMAS
WSREPORT ALL

SELECT 0
DISPLAY
TUP

SELECT 2
DISPLAY
TUP

* ---------------------------------------------------------
* RELOAD FULL SCHEMA AGAIN
* ---------------------------------------------------------
SCHEMAS LOAD mem64_test.dtschemas

SCHEMAS
WSREPORT ALL

SELECT 0
DISPLAY
TUP

SELECT 1
DISPLAY
TUP

SELECT 2
DISPLAY
TUP

* ---------------------------------------------------------
* OPTIONAL MEMO TOOL CHECK
* ---------------------------------------------------------
SELECT 0
MEMO STATUS
MEMO VERIFY

SELECT 1
MEMO STATUS
MEMO VERIFY

SELECT 2
MEMO STATUS
MEMO VERIFY

* ---------------------------------------------------------
* FINAL EXPECTATIONS
* ---------------------------------------------------------
ECHO EXPECT AREA 0 = X64_A -> alpha updated
ECHO EXPECT AREA 1 = X64_B -> bravo updated
ECHO EXPECT AREA 2 = X64_C -> charlie updated
ECHO EXPECT SCHEMAS CLOSE 1 not to disturb 0 and 2
ECHO EXPECT SCHEMAS LOAD mem64_test.dtschemas to restore all three

ECHO DONE