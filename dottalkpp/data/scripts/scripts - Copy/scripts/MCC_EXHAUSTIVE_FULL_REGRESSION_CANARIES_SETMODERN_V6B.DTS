ECHO ===== STUDENTS =====
SELECT STUDENTS
STRUCT
COUNT
RECNO
LIST 3
RECNO
TUPLE *
TOP
RECNO

ECHO ===== STUDENTS / PUBLIC INDEX WORKFLOW =====
SET INDEX TO STUDENTS.cdx
SET ORDER TO TAG LNAME
AREA
ECHO [ORDER-ENTRY CANARY] TOP immediately after SET ORDER:
TOP
RECNO
LIST 5

ECHO ===== LOCATE / FIND / SEEK =====
LOCATE lname = Anderson
RECNO
TUPLE *
TOP
LOCATE lname = Taylor
RECNO
TUPLE *
TOP
FIND Taylor
TOP
FIND White
TOP
SEEK Davis
RECNO
TUPLE *
TOP

SET ORDER TO TAG FNAME
AREA
ECHO [ORDER-ENTRY CANARY] TOP immediately after SET ORDER:
TOP
RECNO
LIST 5
SEEK Alex
RECNO
TUPLE *
FIND Ava
LOCATE fname = Ava
TUPLE *
SET ORDER TO TAG LNAME
AREA
TOP
RECNO

ECHO ===== ORDERED CURSOR CANARIES =====
SEEK Taylor
RECNO
TUPLE *
LIST 1

LOCATE lname = Davis
RECNO
TUPLE *
LIST 1

SET ORDER TO TAG FNAME
SEEK Ava
RECNO
TUPLE *
LIST 1

LOCATE fname = Ava
RECNO
TUPLE *
LIST 1

SET ORDER TO TAG LNAME
TOP
RECNO

ECHO ===== BOOLEAN / PREDICATE GRAMMAR =====
TOP
LOCATE lname = Taylor
LIST 1
BOOLEAN (GPA > 3)
BOOLEAN (GPA < 3)
BOOLEAN (GPA >= 2 AND GPA <= 4)

ECHO ===== SMARTLIST =====
RECNO
SMARTLIST 5 FOR GPA >= 3.5
RECNO

ECHO ===== AGGREGATES =====
SUM GPA
AVERAGE GPA
AVG GPA
MIN GPA
MAX GPA

ECHO ===== STUDENTS DATE FIELDS + DATE ALGEBRA =====
LOCATE lname = Taylor
TUPLE DOB
TUPLE ENROLL_D
CALC DOB
CALC DOB + 1
CALC DOB - 1
CALC DATEADD(DOB, 30)
CALC DATEDIFF(DOB, DATE())
CALC DATE() - DOB

ECHO ===== RELATIONS ENGINE =====
REL LIST
REL CLEAR ALL
REL ADD STUDENTS ENROLL ON SID
REL ADD ENROLL CLASSES ON CLS_ID
REL LIST
REL REFRESH
REL_LIST
REL_REFRESH
CMDREL
CMDREL LIST
CMDREL REFRESH

ECHO ===== TABLE BUFFER CANARY =====
SELECT STUDENTS
SET INDEX TO STUDENTS.cdx
SET ORDER TO TAG LNAME
LOCATE lname = Taylor
LIST 1
TUPLE *
TABLE ON
REPLACE FNAME WITH "DeraldNew"
ECHO [BUF-VIS-1] TUPLE should show buffered value immediately:
TUPLE *
ECHO [BUF-VIS-2] LIST should still show persisted/indexed value until COMMIT:
LIST 1
COMMIT
ECHO [BUF-VIS-3] After COMMIT, verify by SEEK:
SEEK Taylor
LIST 1
REPLACE FNAME WITH "Derald"
COMMIT
TABLE OFF
SEEK Taylor
LIST 1

ECHO ===== CALCWRITE REVERSIBLE WRITE (GPA +/- 0.01) =====
SELECT STUDENTS
SET INDEX TO STUDENTS.cdx
SET ORDER TO TAG LNAME
LOCATE lname = Taylor
TABLE ON
TUPLE GPA
CALC GPA = GPA + 0.01
TUPLE GPA
COMMIT
SEEK Taylor
LIST 1
CALC GPA = GPA - 0.01
COMMIT
SEEK Taylor
LIST 1
TABLE OFF

ECHO ===== LEGACY / TRANSITIONAL REINDEX CANARIES =====
SELECT BUILDING
SET INDEX TO BUILDING.cdx
SET ORDER TO TAG BLDG
REINDEX
SHOW INDEX

SELECT STUDENTS
SET INDEX TO STUDENTS.cdx
SET ORDER TO TAG LNAME
REINDEX
SHOW INDEX
INDEXSEEK "DAVIS"

ECHO ===== FILE OPS (SAFE, under tmp/) =====
! echo DotTalkTmpProbe>tmp/dt_probe.txt
! echo DotTalkTmpProbe2>tmp/dt_probe2.txt
DIR tmp/dt_probe.txt
DIR tmp/dt_probe2.txt
ERASE tmp/dt_probe.txt
ERASE tmp/dt_probe2.txt
DIR tmp

ECHO ===== SQLITE =====
SQLITE OPEN "tmp/sql_regression.sqlite"
SQLITE EXEC CREATE TABLE IF NOT EXISTS t(x INT);
SQLITE EXEC DELETE FROM t;
SQLITE EXEC INSERT INTO t(x) VALUES (1);
SQLITE EXEC INSERT INTO t(x) VALUES (2);
SQLITE SELECT SELECT * FROM t;
SQLITE CLOSE

ECHO ===== DOTSCRIPT / GO (REAL, NOT USAGE) =====
! echo SET ECHO ON>tmp/mini_regression.dts
! echo ECHO MINI_DOTSCRIPT_OK>>tmp/mini_regression.dts
DOTSCRIPT tmp/mini_regression.dts
SET ECHO OFF
ECHO GO_OK
GO TOP

ECHO ===== SCRIPTING BLOCKS (SAFE NON-LOOPING) =====
IF .F.
    ECHO IF_BRANCH_RAN_UNEXPECTED
ELSE
    ECHO ELSE_BRANCH_RAN_OK
ENDIF

WHILE .F.
    ECHO WHILE_BODY_RAN_UNEXPECTED
ENDWHILE

UNTIL .T.
    ECHO UNTIL_BODY_RAN_UNEXPECTED
ENDUNTIL

SELECT BUILDING
SET INDEX TO BUILDING.cdx
SET ORDER TO TAG BLDG
TOP
SCAN
    TUPLE *
ENDSCAN
SET ORDER TO 0

ECHO ===== TUPTALK MINI =====
SELECT STUDENTS
TUPTALK RESET
TUPTALK PUSH ALL
TUPTALK PUSH FILTER CND
TUPTALK PUSH 3
TUPTALK PUSH ROW
TUPTALK LIST
TUPTALK NORMALIZE
TUPTALK DUMP
TUPTALK EXPORT CSV students_norm.csv
TUPTALK EXPORT TSV students_norm.tsv

ECHO ===== SQLITE SMOKE (INLINE) =====
SQLITE VERSION
SQLITE OPEN :memory:
SQLITE EXEC CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT, n INTEGER);
SQLITE EXEC INSERT INTO t (name, n) VALUES ('alpha', 10);
SQLITE EXEC INSERT INTO t (name, n) VALUES ('bravo', 20);
SQLITE EXEC INSERT INTO t (name, n) VALUES ('charlie', 30);
SQLITE SELECT SELECT id, name, n FROM t ORDER BY id;
SQLITE CLOSE

ECHO ===== DEV LMDB UTILITY PROBES =====
LMDB
LMDB OPEN indexes/STUDENTS.cdx.d
LMDB USE LNAME
LMDB INFO
LMDB SEEK WILSON
LMDB SCAN A D
LMDB CLOSE

LMDB OPEN indexes/STUDENTS.cdx.d
LMDB USE FNAME
LMDB INFO
LMDB SEEK AVA
LMDB SCAN M Z
LMDB CLOSE

ECHO ===== SECTION 2: KNOWN-FAIL / OBSERVATION CANARIES =====

ECHO ===== DATE COMPARISON CANARIES (KNOWN CURRENT FAILURES) =====
ECHO [KNOWN-FAIL] CURRENT EXPECT .F.:
CALC ((DATE() + 2) > DATE())
ECHO [KNOWN-FAIL] CURRENT EXPECT .F.:
CALC ((DATE() - 2) < DATE())
ECHO [KNOWN-FAIL] CURRENT EXPECT .F.:
CALC (CTOD("2000-01-01") + 1 = CTOD("2000-01-02"))
ECHO [KNOWN-FAIL] CURRENT EXPECT .F.:
CALC (CTOD("2000-01-01") - 1 = CTOD("1999-12-31"))
ECHO [KNOWN-FAIL] CURRENT EXPECT .F.:
CALC (DATEDIFF(DOB, DATE()) = -(DATE() - DOB))

ECHO ===== WHERE / SHOW FILTER OBSERVATION =====
SELECT STUDENTS
SET INDEX TO STUDENTS.cdx
SET ORDER TO TAG LNAME
TOP
LOCATE lname = Taylor
WHERE GPA >= 3.5
SHOW TABLE
SHOW INDEX
COUNT
TOP
SMARTLIST 5 FOR GPA >= 3.5

ECHO ===== SET FILTER UNDER ORDER (CURSOR-STABLE PROBES) =====
SET FILTER TO LNAME = "TAYLOR"
COUNT
TOP
LIST 20
SET FILTER TO

SET FILTER TO LNAME = "ANDERSON"
COUNT
TOP
LIST 20
SET FILTER TO

SET FILTER TO FNAME = "AVA"
COUNT
TOP
LIST 20
SET FILTER TO

ECHO ===== CLEAN SHUTDOWN =====
SET ORDER TO 0
SCHEMAS
SCHEMAS CLOSE
ECHO ===== V6B REGRESSION END =====
QUIT