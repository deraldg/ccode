SET ECHO OFF
* ============================================================
* MCC_EXHAUSTIVE_FULL_REGRESSION_CANARIES_SETMODERN_V6B.DTS
*
* V6B: Same as V6, but:
*  - Removed any non-DotTalk “runner notes” after QUIT (PS-safe).
*  - Keep uppercase .cdx filenames for WSL/case-sensitive.
*  - Keep TOP-before-LIST for FILTER probes.
* ============================================================

ECHO ===== V6B REGRESSION START =====
COLOR DEFAULT
VERSION

ECHO ===== SECTION 1: AUTOMATED SAFE CORE =====

ECHO ===== HELP / CATALOG SANITY =====
* HELP
* CMDHELP
* FOXHELP
* PREDHELP

ECHO ===== PATHS / ROOTS =====
SET PATH
SET PATH RESET
SET PATH
DIR
DIR dbf
DIR indexes
DIR tmp

ECHO ===== STARTUP / DIAGNOSTICS =====
INIT
DBAREA
DBAREAS
AREA
STATUS
WSREPORT

ECHO [NOTE] SHOW currently supports TABLE / COLUMNS / INDEX in this build:
SHOW TABLE
SHOW COLUMNS
SHOW INDEX

ECHO ===== SCHEMAS BRING-UP =====
SCHEMAS
SCHEMAS CLOSE
REL CLEAR ALL
SCHEMAS OPEN DBF
SCHEMAS

ECHO ===== BASELINE CLOCK / DATE-TIME =====
DATE
TODAY
TIME
NOW
DATETIME
CALC DATE()
CALC TODAY()
CALC TIME()
CALC NOW()
CALC DATETIME()
CALC (DATE() = TODAY())
CALC (NOW() = DATETIME())

ECHO ===== DATE ALGEBRA / FUNCTION BASELINE =====
CALC DATE() + 2
CALC DATE() - 2
CTOD 2000-01-01
CTOD "2000-01-01"
CTOD "2000/01/01"
CTOD 20000101
CALC CTOD("2000-01-01")
CALC DTOC(CTOD("2000-01-01"))
DATEADD 20000101, 30
DATEADD 20000101, -30
DATEDIFF 20000101, 20000103
CALC DATEADD(DATE(), 30)
CALC DATEDIFF(CTOD("2000-01-01"), DATE())

ECHO ===== RHS EXPRESSION SANITY =====
CALC (3 = 1 + 2)
CALC ((1 + 2) = (6 / 2))
CALC ((1 + 2 * 3) = (1 + (2 * 3)))

ECHO ===== STRING / CHAR COMMANDS =====
ALLTRIM "  hi  "
LTRIM "  hi"
RTRIM "hi  "
TRIM "hi  "
UPPER "aBc"
LOWER "aBc"
PROPER "joHN"
LEN "ABCDE"
LEFT "ABCDE", 3
RIGHT "ABCDE", 2
SUBSTR "ABCDE", 2, 3
AT "CD", "ABCDE"
ATC "cd", "ABCDE"
CHR 65
ASC "A"
SPACE 3
REPLICATE "x", 5
PADC "hi", 6
PADL "hi", 6
PADR "hi", 6
STUFF "ABCDE", 2, 2, "ZZ"
STR 123
VAL "123.45"
LIKE "SMITH", "SMI%"

ECHO ===== EXPECTED-USAGE / ERROR CANARIES (NON-FATAL) =====
TRANSFORM 123
NORMALIZE "  a  b  "
MULTIREP "banana", "a", "A", "n", "N"

ECHO ===== CONCAT / STRCAT =====
CONCAT "A", "B"
CALC CONCAT("A","B")
STRCAT "A", "B"

ECHO ===== TABLES: CORE TABLE / ORDER / CURSOR PROBES =====
ECHO [NOTE] Probe pairs: RECNO before+after LIST / SMARTLIST / WHERE to observe cursor restore behavior.

ECHO ===== BUILDING =====
SELECT BUILDING
AREA
STRUCT
FIELDS
COUNT
RECNO
LIST 3
RECNO
DISPLAY
RECORDVIEW
TOP
RECNO
SKIP 1
RECNO
BOTTOM
RECNO
TOP
RECNO
SET INDEX TO BUILDING.cdx
SET ORDER TO TAG BLDG
AREA
TOP
RECNO
LIST 3
SET ORDER TO 0
LIST 3
SET UNIQUE FIELD BLDG ON
SET UNIQUE FIELD BLDG OFF

