* ============================================================
* X64SAMP2_CURRENCY_TEST.DTS
* ============================================================

SET ECHO OFF

USE X64SAMP2
SELECT X64SAMP2
CLOSE
ERASE X64SAMP2.DBF CONFIRM

CREATE X64 X64SAMP2 ( ;
    REC_ID      C(16), ;
    NAME        C(40), ;
    NOTE_S      C(60), ;
    STATUS      C(12), ;
    COUNT_N     N(10,0), ;
    AMOUNT_N    N(12,2), ;
    RATIO_F     F(18,6), ;
    EVENT_DT    D, ;
    IS_ACTIVE   L, ;
    MEMO_REF    M, ;
    INT32_I     I, ;
    DOUBLE_B    B, ;
    AMOUNT      Y, ;
    AMOUNT_CU   C(3), ;
    PAD1        C(80), ;
    PAD2        C(80) ;
)

USE X64SAMP2
SELECT X64SAMP2
AREA
STRUCT

APPEND

MULTIREP ;
    REC_ID WITH "REC000000000001", ;
    NAME WITH "X64 SAMPLE ROW 1", ;
    NOTE_S WITH "X64 all-fields sample with paired currency", ;
    STATUS WITH "ACTIVE", ;
    COUNT_N WITH 12345, ;
    AMOUNT_N WITH 9876.54, ;
    RATIO_F WITH 0.125, ;
    EVENT_DT WITH TODAY, ;
    IS_ACTIVE WITH T, ;
    INT32_I WITH 9876543, ;
    DOUBLE_B WITH 7.25, ;
    AMOUNT WITH 88.125, ;
    AMOUNT_CU WITH usd

REPLACE MEMO_REF WITH ""

TUP
DISPLAY
LIST

MULTIREP AMOUNT_CU WITH US
MULTIREP AMOUNT_CU WITH USDX
MULTIREP AMOUNT_CU WITH 12$

CLOSE
USE X64SAMP2
SELECT X64SAMP2
LIST
DISPLAY