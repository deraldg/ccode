ECHO OFF
SET TALK ON

* =========================================================
* MULTI-AREA X64 MEMO HARMONY TEST
* =========================================================
* PURPOSE
*   1) Open several x64 memo tables at once
*   2) Verify each area keeps its own memo state
*   3) Verify DISPLAY/TUP resolve the correct memo text per area
*   4) Verify SCHEMAS CLOSE does not disturb surviving areas
* =========================================================

CLOSE ALL
SCHEMAS CLOSE

ERASE X64_A CONFIRM
ERASE X64_B CONFIRM
ERASE X64_C CONFIRM

* ---------------------------------------------------------
* BUILD TABLE A
* ---------------------------------------------------------
CREATE X64 X64_A (ID N(8,0), TITLE C(20), NOTES M)
APPEND
REPLACE ID WITH 1
REPLACE TITLE WITH A1
REPLACE NOTES WITH "alpha one"
CLOSE

* ---------------------------------------------------------
* BUILD TABLE B
* ---------------------------------------------------------
CREATE X64 X64_B (ID N(8,0), TITLE C(20), NOTES M)
APPEND
REPLACE ID WITH 1
REPLACE TITLE WITH B1
REPLACE NOTES WITH "bravo one"
CLOSE

* ---------------------------------------------------------
* BUILD TABLE C
* ---------------------------------------------------------
CREATE X64 X64_C (ID N(8,0), TITLE C(20), NOTES M)
APPEND
REPLACE ID WITH 1
REPLACE TITLE WITH C1
REPLACE NOTES WITH "charlie one"
CLOSE

* ---------------------------------------------------------
* OPEN ALL TABLES INTO SEPARATE AREAS
* ---------------------------------------------------------
SCHEMAS OPEN dbf

SCHEMAS
WSREPORT ALL

* ---------------------------------------------------------
* CHECK AREA 0
* ---------------------------------------------------------
SELECT 0
AREA
DISPLAY
TUP

* ---------------------------------------------------------
* CHECK AREA 1
* ---------------------------------------------------------
SELECT 1
AREA
DISPLAY
TUP

* ---------------------------------------------------------
* CHECK AREA 2
* ---------------------------------------------------------
SELECT 2
AREA
DISPLAY
TUP

* ---------------------------------------------------------
* UPDATE EACH AREA SEPARATELY
* ---------------------------------------------------------
SELECT 0
REPLACE NOTES WITH "alpha updated"
DISPLAY
TUP

SELECT 1
REPLACE NOTES WITH "bravo updated"
DISPLAY
TUP

SELECT 2
REPLACE NOTES WITH "charlie updated"
DISPLAY
TUP

* ---------------------------------------------------------
* RECHECK EACH AREA
* ---------------------------------------------------------
SELECT 0
DISPLAY
TUP

SELECT 1
DISPLAY
TUP

SELECT 2
DISPLAY
TUP

* ---------------------------------------------------------
* CLOSE ONE AREA ONLY
* ---------------------------------------------------------
SCHEMAS CLOSE 1

SCHEMAS
WSREPORT ALL

SELECT 0
DISPLAY
TUP

SELECT 2
DISPLAY
TUP

* ---------------------------------------------------------
* REOPEN CLOSED TABLE
* ---------------------------------------------------------
SELECT 1
USE X64_B
DISPLAY
TUP

* ---------------------------------------------------------
* FINAL EXPECTATIONS
* ---------------------------------------------------------
ECHO EXPECT X64_A -> alpha updated
ECHO EXPECT X64_B -> bravo updated
ECHO EXPECT X64_C -> charlie updated
ECHO EXPECT closing area 1 not to disturb areas 0 and 2

ECHO DONE